-- [[ UTILITY: ECHO RIPPLE EFFECT ]]
local function CreateRipple(obj)
    task.spawn(function()
        local mouse = Player:GetMouse()
        local relPos = Vector2.new(mouse.X - obj.AbsolutePosition.X, mouse.Y - obj.AbsolutePosition.Y)
        
        local ripple = Instance.new("Frame")
        ripple.BackgroundColor3 = Color3.new(1, 1, 1)
        ripple.BackgroundTransparency = 0.6
        ripple.ZIndex = obj.ZIndex + 1
        ripple.Position = UDim2.new(0, relPos.X, 0, relPos.Y)
        ripple.Size = UDim2.new(0, 0, 0, 0)
        ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        ripple.Parent = obj
        
        Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
        obj.ClipsDescendants = true
        
        local tween = TweenService:Create(ripple, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 500, 0, 500),
            BackgroundTransparency = 1
        })
        
        tween:Play()
        tween.Completed:Wait()
        ripple:Destroy()
    end)
end

