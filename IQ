    btn.MouseButton1Click:Connect(function()
        CreateRipple(btn)
        for _, v in pairs(TabBar:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = DarkGray end end
        btn.BackgroundColor3 = Crimson; for _, f in pairs(Container:GetChildren()) do if f:IsA("Frame") then f.Visible = false end end
        frame.Visible = true
