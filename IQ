local function CreateTab(name, active)
    local btn = Instance.new("TextButton", TabBar)
    btn.Size = UDim2.new(0, 90, 1, 0); btn.BackgroundColor3 = active and Crimson or DarkGray; btn.Text = name:upper(); btn.TextColor3 = Color3.new(1, 1, 1); btn.Font = Enum.Font.GothamBold; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
